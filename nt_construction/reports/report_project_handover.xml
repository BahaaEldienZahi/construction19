<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_project_handover" model="ir.actions.report">
        <field name="name">Handover / Delivery Certificate</field>
        <field name="model">project.handover</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_project_handover_document</field>
        <field name="report_file">nt_construction.report_project_handover_document</field>
        <field name="print_report_name">'Handover Certificate - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_project_handover"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_project_handover_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h2>Handover / Delivery Certificate</h2>
                                <h4 t-field="o.name"/>
                            </div>
                            <div class="text-end">
                                <span class="badge rounded-pill text-bg-light border" t-field="o.state"/>
                            </div>
                        </div>

                        <table class="table table-sm mt-3" style="width:65%">
                            <tr><td><strong>Project</strong></td><td><span t-field="o.project_id.name"/></td></tr>
                            <tr><td><strong>Date</strong></td><td><span t-field="o.date"/></td></tr>
                            <tr><td><strong>Provisional Handover Date</strong></td><td><span t-field="o.provisional_handover_date"/></td></tr>
                            <tr><td><strong>Defects Liability Period</strong></td><td><span t-field="o.defects_liability_months"/> months</td></tr>
                            <tr><td><strong>DLP End Date</strong></td><td><span t-field="o.defects_liability_end_date"/></td></tr>
                            <tr t-if="o.final_handover_date"><td><strong>Final Handover Date</strong></td><td><span t-field="o.final_handover_date"/></td></tr>
                        </table>

                        <h5 class="mt-3">Punch List / Snag Items</h5>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr class="table-active">
                                    <th>Description</th>
                                    <th>Location</th>
                                    <th>Responsible</th>
                                    <th>Status</th>
                                    <th>Reported</th>
                                    <th>Closed</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.punch_list_ids" t-as="p">
                                    <td><span t-field="p.description"/></td>
                                    <td><span t-field="p.location"/></td>
                                    <td><span t-field="p.responsible_party"/></td>
                                    <td><span t-field="p.status"/></td>
                                    <td><span t-field="p.date_reported"/></td>
                                    <td><span t-field="p.date_closed"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <p>
                            <strong>Open items: </strong><span t-field="o.punch_list_open_count"/> /
                            <span t-field="o.punch_list_total_count"/>
                        </p>

                        <h5 class="mt-3">Retention Release</h5>
                        <table class="table table-sm" style="width:65%">
                            <tr><td><strong>Total Retention Held</strong></td><td class="text-end"><span t-field="o.retention_held_total"/></td></tr>
                            <tr>
                                <td>Stage 1 (<span t-field="o.retention_release_stage1_percentage"/>%)</td>
                                <td class="text-end"><span t-field="o.retention_release_stage1_amount"/></td>
                            </tr>
                            <tr>
                                <td>Stage 2 (<span t-field="o.retention_release_stage2_percentage"/>%)</td>
                                <td class="text-end"><span t-field="o.retention_release_stage2_amount"/></td>
                            </tr>
                        </table>

                        <h5 class="mt-3" t-if="o.final_acceptance_notes">Final Acceptance Notes</h5>
                        <p t-field="o.final_acceptance_notes"/>

                        <div class="row mt-5 pt-5">
                            <div class="col-6 text-center"><p>For the Contractor</p></div>
                            <div class="col-6 text-center"><p>For the Client</p></div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

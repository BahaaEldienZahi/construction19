<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_work_inspection" model="ir.actions.report">
        <field name="name">Ш·Щ„ШЁ ЩҒШӯШө / Work Inspection Request (WIR/MIR)</field>
        <field name="model">work.inspection</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_work_inspection_document</field>
        <field name="report_file">nt_construction.report_work_inspection_document</field>
        <field name="print_report_name">'Ш·Щ„ШЁ ЩҒШӯШө - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_work_inspection"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_work_inspection_document">
        <t t-call="web.html_container"><t t-foreach="docs" t-as="o"><t t-call="web.external_layout">
            <div class="page">
                <div class="text-center mb-3"><h2 style="color:#34495e; margin-bottom:0;">Ш·Щ„ШЁ ЩҒШӯШө ШЈШ№Щ…Ш§Щ„ / Work Inspection Request (WIR/MIR)</h2><h4 style="color:#7f8c8d;" t-field="o.name"/></div>
                <hr style="border-top:3px solid #34495e;"/>
                <table class="table table-sm mt-2" style="width:100%">
                    <tr><td style="width:30%"><strong>Ш§Щ„Щ…ШҙШұЩҲШ№ / Project</strong></td><td><span t-field="o.project_id.name"/></td><td style="width:30%"><strong>ЩҶЩҲШ№ Ш§Щ„ЩҒШӯШө / Type</strong></td><td><span t-field="o.inspection_type"/></td></tr>
                    <tr><td><strong>ШӘШ§ШұЩҠШ® Ш§Щ„Ш·Щ„ШЁ / Request Date</strong></td><td><span t-field="o.date"/></td><td><strong>ШӘШ§ШұЩҠШ® Ш§Щ„ЩҒШіШөШӯ / Inspection Date</strong></td><td><span t-field="o.inspection_date"/></td></tr>
                    <tr><td><strong>Ш§Щ„Щ…ЩҲЩӮШ№ / Location</strong></td><td><span t-field="o.location"/></td><td><strong>Ш§Щ„Щ…ШөЩҮШ§Ші Ш§Щ„Щ…Ш–ЩӮШө ШҜ / Inspector</strong></td><td><span t-field="o.inspector_id.name"/></td></tr>
                    <tr><td><strong>Ш§Щ„ШӯШ§Щ„Ш© / Status</strong></td><td colspan="3"><span t-field="o.state"/></td></tr>
                </table>
                <table class="table table-sm table-bordered mt-2" t-if="o.boq_line_ids"><thead><tr style="background-color:#34495e; color:white;"><th>ШЁЩҶЩҲШҜ Ш§Щ„Щ„ШҘЩ„  BOQ Ш§Щ„Щ…ЩӮШӘШЁШ·ШЁ / Related BOQ Items</th></tr></thead><tbody><tr t-foreach="o.boq_line_ids" t-as="b"><td><small t-field="b.code"/> вҖ” <span t-field="b.name"/></td></tr></tbody></table>
                <h5 class="mt-3" style="color:#34495e;">ЩҶШ·Ш§ЩӮ Ш§Щ„ЩҠ-Шө / Scope of Inspection</h5>
                <p t-field="o.description" style="background-color:#f2f3f4; padding:8px; border:1px solid #d5dbdb; border-radius:4px;"/>
                <div t-if="o.inspection_result"><h5 class="mt-3" style="color:#34495e;">ЩҶШӘЩҠШ§ШӘ Ш§Щ„ЩӮШөШӯ / Inspection Result</h5><p t-field="o.inspection_result" style="background-color:#f2f3f4; padding:8px; border:1px solid #d5dbdb; border-radius:4px;"/>
                <p><strong>Щ…ШӯШ§ШІЩӮ / Conforming: </strong><span t-if="o.is_conforming" style="color:#27ae60; font-weight:bold;">ШҜШ№Щ… / Yes</span><span t-else="" style="color:#c0392b; font-weight:bold;">Ш§Щ„ / No</span></p>
                <div t-if="not o.is_conforming and o.rejection_reason"><strong style="color:#c0392b;">ШіШЁШЁ Ш§Щ„ШұЩ„Ш¶ / Rejection Reason</strong><p t-field="o.rejection_reason" style="color:#c0392b; background-color:#fdedec; padding:8px; border:1px solid #f5b7b1; border-radius:4px;"/></div></div>
                <div class="row mt-5 pt-5"><div class="col-4 text-center"><hr style="width:60%;"/><p>Щ…ЩӮШҜЩ… Ш§Щ„ЫҙШ§Щ„ШЁ / Requested By</p></div><div class="col-4 text-center"><hr style="width:60%;"/><p>Ш§Щ„Щ…ШөЩҮШ§Ші Ш§Щ„Щ…–ЙӮШө ШҜ / Inspector</p></div><div class="col-4 text-center"><hr style="width:60%;"/><p>Ш§Щ„Щ…ЩҸШ№ШӘЩ…ШҜ / Approved By</p></div></div>
            </div>
        </t></t></t>
    </template>
</odoo>

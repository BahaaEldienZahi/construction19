<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_work_measurement" model="ir.actions.report">
        <field name="name">Work Measurement Sheet</field>
        <field name="model">work.measurement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_work_measurement_document</field>
        <field name="report_file">nt_construction.report_work_measurement_document</field>
        <field name="print_report_name">'Work Measurement - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_work_measurement"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_work_measurement_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h2>Work Measurement Sheet</h2>
                                <h4 t-field="o.name"/>
                            </div>
                            <div class="text-end">
                                <span class="badge rounded-pill text-bg-light border" t-field="o.state"/>
                            </div>
                        </div>

                        <table class="table table-sm mt-3" style="width:60%">
                            <tr><td><strong>Project</strong></td><td><span t-field="o.project_id.name"/></td></tr>
                            <tr><td><strong>Date</strong></td><td><span t-field="o.date"/></td></tr>
                            <tr t-if="o.period_from or o.period_to">
                                <td><strong>Period</strong></td>
                                <td><span t-field="o.period_from"/> — <span t-field="o.period_to"/></td>
                            </tr>
                        </table>

                        <table class="table table-sm table-bordered mt-3">
                            <thead>
                                <tr class="table-active">
                                    <th>BOQ Item</th>
                                    <th class="text-end">Qty Executed</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.summary_line_ids" t-as="line">
                                    <td><span t-field="line.boq_line_id.name"/></td>
                                    <td class="text-end"><span t-field="line.quantity_executed"/></td>
                                    <td class="text-end"><span t-field="line.unit_price"/></td>
                                    <td class="text-end"><span t-field="line.amount"/></td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr class="border-top">
                                    <td colspan="3"><strong>Total Executed Value</strong></td>
                                    <td class="text-end"><strong><span t-field="o.total_executed_value"/></strong></td>
                                </tr>
                            </tfoot>
                        </table>

                        <h5 class="mt-3" t-if="o.daily_report_ids">Based on Daily Reports</h5>
                        <ul>
                            <li t-foreach="o.daily_report_ids" t-as="dr">
                                <span t-field="dr.name"/> — <span t-field="dr.date"/>
                            </li>
                        </ul>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

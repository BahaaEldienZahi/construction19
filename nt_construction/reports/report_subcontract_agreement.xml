<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_subcontract_agreement" model="ir.actions.report">
        <field name="name">اتفاقية مقاولة باطن / Subcontract Agreement</field>
        <field name="model">subcontract.agreement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_subcontract_agreement_document</field>
        <field name="report_file">nt_construction.report_subcontract_agreement_document</field>
        <field name="print_report_name">'اتفاقية مقاول باطن - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_subcontract_agreement"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_subcontract_agreement_document">
        <t t-call="web.html_container"><t t-foreach="docs" t-as="o"><t t-call="web.external_layout">
            <div class="page">
                <div class="text-center mb-3"><h2 style="color:#8e44ad; margin-bottom:0;">اتفءقية مقاولة باطن / Subcontract Agreement</h2><h4 style="color:#7f8c8d;" t-field="o.name"/></div>
                <hr style="border-top:3px solid #8e44ad;"/>
                <table class="table table-sm mt-2" style="width:100%">
                    <tr><td style="width:30%"><strong>المشروع / Project</strong></td><td><span t-field="o.project_id.name"/></td><td style="width:30%"><strong>مقاول الباطن / Subcontractor</strong></td><td><span t-field="o.partner_id.name"/></td></tr>
                    <tr><td><strong>التاريخ / Date</strong></td><td><span t-field="o.date"/></td><td><strong>الحالة / Status</strong></td><td><span t-field="o.state"/></td></tr>
                    <tr><td><strong>تاريخ البداية / Start Date</strong></td><td><span t-field="o.start_date"/></td><td><strong>تاريخ النهاية / Completion Date</strong></td><td><span t-field="o.completion_date"/></td></tr>
                    <tr><td><strong>نسبة الضمان / Retention %</strong></td><td><span t-field="o.retention_percentage"/>%</td><td><strong>قيم/تة العقد / Contract Value</strong></td><td><span t-field="o.contract_value"/></td></tr>
                </table>
                <h5 class="mt-3" t-if="o.scope_of_work" style="color:#8e44ad;">نطاق العمل / Scope of Work</h5>
                <p t-field="o.scope_of_work" style="background-color:#f4ecf7; padding:8px; border:1px solid #d7bde2; border-radius:4px;"/>
                <h5 class="mt-3" style="color:#8e44ad;">بنود العقد / Agreement Lines</h5>
                <table class="table table-sm table-bordered mt-2">
                    <thead><tr style="background-color:#8e44ad; color:white;"><th>الكود / Code</th><th>البيان / Description</th><th>الوحدة / UoM</th><th class="text-end">الكمية / Qty</th><th class="text-end">سعر الوحدة / Unit Price</th><th class="text-end">الإجمالي / Subtotal</th></tr></thead>
                    <tbody><tr t-foreach="o.line_ids" t-as="line"><td><span t-field="line.code"/></td><td><span t-field="line.name"/></td><td><span t-field="line.uom_id.name"/></td><td class="text-end"><span t-field="line.quantity"/></td><td class="text-end"><span t-field="line.unit_price"/></td><td class="text-end"><span t-field="line.subtotal"/></td></tr></tbody>
                    <tfoot><tr style="background-color:#f4ecf7; font-weight:bold; border-top:2px solid #8e44ad;"><td colspan="5">إجمالي قيمة العقد / Total Contract Value</td><td class="text-end"><span t-field="o.total_value"/></td></tr></tfoot>
                </table>
                <div class="row mt-5 pt-5"><div class="col-6 text-center"><hr style="width:60%;"/><p>المصام العام / For the Contractor</p></div><div class="col-6 text-center"><hr style="width:60%;"/><p>مقاول الباطن / For the Subcontractor</p><p style="font-size:12px;" t-field="o.partner_id.name"/></div></div>
            </div>
        </t></t></t>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_boq_variation_order" model="ir.actions.report">
        <field name="name">Variation Order</field>
        <field name="model">boq.variation.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_boq_variation_order_document</field>
        <field name="report_file">nt_construction.report_boq_variation_order_document</field>
        <field name="print_report_name">'Variation Order - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_boq_variation_order"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_boq_variation_order_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h2>Variation Order</h2>
                                <h4 t-field="o.name"/>
                            </div>
                            <div class="text-end">
                                <span class="badge rounded-pill text-bg-light border" t-field="o.state"/>
                            </div>
                        </div>

                        <table class="table table-sm mt-3" style="width:60%">
                            <tr><td><strong>Project</strong></td><td><span t-field="o.project_id.name"/></td></tr>
                            <tr><td><strong>Date</strong></td><td><span t-field="o.date"/></td></tr>
                        </table>

                        <h5 class="mt-3" t-if="o.reason">Reason / Justification</h5>
                        <p t-field="o.reason"/>

                        <table class="table table-sm table-bordered mt-3">
                            <thead>
                                <tr class="table-active">
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th>UoM</th>
                                    <th class="text-end">Qty Change</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Amount Change</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.line_ids" t-as="line">
                                    <td><span t-field="line.code"/></td>
                                    <td><span t-field="line.name"/></td>
                                    <td><span t-field="line.uom_id.name"/></td>
                                    <td class="text-end"><span t-field="line.delta_qty"/></td>
                                    <td class="text-end"><span t-field="line.unit_price"/></td>
                                    <td class="text-end"><span t-field="line.delta_amount"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="row mt-3">
                            <div class="col-6 offset-6">
                                <table class="table table-sm">
                                    <tr class="border-top">
                                        <td><strong>Total Change</strong></td>
                                        <td class="text-end"><strong><span t-field="o.total_delta_amount"/></strong></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row mt-5 pt-5">
                            <div class="col-4 text-center"><p>Prepared By</p></div>
                            <div class="col-4 text-center"><p>Reviewed By (L1)</p></div>
                            <div class="col-4 text-center"><p>Approved By (L2)</p></div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_boq_variation_order" model="ir.actions.report">
        <field name="name">أمر تغيير / Variation Order</field>
        <field name="model">boq.variation.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_boq_variation_order_document</field>
        <field name="report_file">nt_construction.report_boq_variation_order_document</field>
        <field name="print_report_name">'أمر تغيير - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_boq_variation_order"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_boq_variation_order_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="text-center mb-3">
                            <h2 style="color:#d35400; margin-bottom:0;">أمر تغيير / Variation Order</h2>
                            <h4 style="color:#7f8c8d;" t-field="o.name"/>
                        </div>
                        <hr style="border-top:3px solid #d35400;"/>

                        <table class="table table-sm mt-2" style="width:100%">
                            <tr>
                                <td style="width:30%"><strong>المشروع / Project</strong></td><td><span t-field="o.project_id.name"/></td>
                                <td style="width:30%"><strong>التاريخ / Date</strong></td><td><span t-field="o.date"/></td>
                            </tr>
                            <tr>
                                <td><strong>الحالة / Status</strong></td><td><span t-field="o.state"/></td>
                                <td><strong>قيمة العقد / Contract Value</strong></td><td><span t-field="o.project_id.contract_value"/></td>
                            </tr>
                        </table>

                        <h5 class="mt-3" t-if="o.reason" style="color:#d35400;">سبب التغيير / Reason / Justification</h5>
                        <p t-field="o.reason" style="background-color:#fef9e7; padding:8px; border:1px solid #f9e79f; border-radius:4px;"/>

                        <h5 class="mt-3" style="color:#d35400;">بنود التغيير / Variation Items</h5>
                        <table class="table table-sm table-bordered mt-2">
                            <thead>
                                <tr style="background-color:#d35400; color:white;">
                                    <th>الكود / Code</th><th>البيان / Description</th><th>الوحدة / UoM</th>
                                    <th class="text-end">تغيير الكمية / Qty Change (+/-)</th>
                                    <th class="text-end">سعر الوحدة / Unit Price</th>
                                    <th class="text-end">التغيير بالمبلغ / Amount Change</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.line_ids" t-as="line">
                                    <td><span t-field="line.code"/></td>
                                    <td><span t-field="line.name"/></td>
                                    <td><span t-field="line.uom_id.name"/></td>
                                    <td class="text-end"><span t-att-style="'color:#27ae60;' if line.delta_qty >= 0 else 'color:#c0392b;'" t-field="line.delta_qty"/></td>
                                    <td class="text-end"><span t-field="line.unit_price"/></td>
                                    <td class="text-end"><span t-att-style="'color:#27ae60;' if line.delta_amount >= 0 else 'color:#c0392b;'" t-field="line.delta_amount"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="row mt-3"><div class="col-6 offset-6">
                        <table class="table table-sm" style="font-size:13px;">
                            <tr style="background-color:#f8f9fa; font-weight:bold; border-top:2px solid #d35400;">
                                <td>صافي التغيير / Net Change</td>
                                <td class="text-end" style="font-size:15px;"><span t-att-style="'color:#27ae60;' if o.total_delta_amount >= 0 else 'color:#c0392b;'" t-field="o.total_delta_amount"/></td>
                            </tr>
                            <tr style="font-size:11px; color:#7f8c8d;">
                                <td>قيمة العقد بعد التغيير / Contract Value After VO</td>
                                <td class="text-end"><span t-esc="o.project_id.contract_value + o.total_delta_amount"/></td>
                            </tr>
                        </table>
                        </div></div>

                        <div class="row mt-5 pt-5">
                            <div class="col-4 text-center"><hr style="width:60%;"/><p>الم/؏عِد / Prepared By</p></div>
                            <div class="col-4 text-center"><hr style="width:60%;"/><p>الم/؏راجع (L1) / Reviewed By</p></div>
                            <div class="col-4 text-center"><hr style="width:60%;"/><p>المُعتمد (L2) / Approved By</p></div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_tender_tender" model="ir.actions.report">
        <field name="name">Tender Summary Sheet</field>
        <field name="model">tender.tender</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_tender_tender_document</field>
        <field name="report_file">nt_construction.report_tender_tender_document</field>
        <field name="print_report_name">'Tender - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_tender_tender"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_tender_tender_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h2>Tender Summary Sheet</h2>
                                <h4 t-field="o.name"/>
                            </div>
                            <div class="text-end">
                                <span class="badge rounded-pill text-bg-light border" t-field="o.state"/>
                            </div>
                        </div>

                        <table class="table table-sm mt-3" style="width:65%">
                            <tr><td><strong>Client</strong></td><td><span t-field="o.client_id.name"/></td></tr>
                            <tr><td><strong>Client Reference</strong></td><td><span t-field="o.client_reference"/></td></tr>
                            <tr><td><strong>Responsible</strong></td><td><span t-field="o.user_id.name"/></td></tr>
                            <tr><td><strong>Submission Deadline</strong></td><td><span t-field="o.submission_deadline"/></td></tr>
                            <tr><td><strong>Opening Date</strong></td><td><span t-field="o.opening_date"/></td></tr>
                            <tr><td><strong>Estimated Value</strong></td><td><span t-field="o.estimated_value"/></td></tr>
                            <tr t-if="o.awarded_value"><td><strong>Awarded Value</strong></td><td><span t-field="o.awarded_value"/></td></tr>
                            <tr t-if="o.date_won"><td><strong>Award Date</strong></td><td><span t-field="o.date_won"/></td></tr>
                        </table>

                        <h5 class="mt-3" t-if="o.description">Description</h5>
                        <p t-field="o.description"/>

                        <table class="table table-sm table-bordered mt-3" t-if="o.boq_line_ids">
                            <thead>
                                <tr class="table-active">
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th>UoM</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.boq_line_ids" t-as="b">
                                    <td><span t-field="b.code"/></td>
                                    <td><span t-field="b.name"/></td>
                                    <td><span t-field="b.uom_id.name"/></td>
                                    <td class="text-end"><span t-field="b.quantity_contracted"/></td>
                                    <td class="text-end"><span t-field="b.unit_price"/></td>
                                    <td class="text-end"><span t-field="b.total_contracted"/></td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr class="border-top">
                                    <td colspan="5"><strong>Total Estimated Value</strong></td>
                                    <td class="text-end"><strong><span t-field="o.boq_total_contracted"/></strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

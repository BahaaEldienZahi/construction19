<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_tender_tender" model="ir.actions.report">
        <field name="name">تقرير مناقصة / Tender Summary</field>
        <field name="model">tender.tender</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_tender_tender_document</field>
        <field name="report_file">nt_construction.report_tender_tender_document</field>
        <field name="print_report_name">'تقرير مناقصة - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_tender_tender"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_tender_tender_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="text-center mb-3">
                            <h2 style="color:#1a5276; margin-bottom:0;">
                                تقرير مناقصة / Tender Summary
                            </h2>
                            <h4 style="color:#7f8c8d;" t-field="o.name"/>
                        </div>

                        <hr style="border-top:3px solid #1a5276;"/>

                        <!-- Key Info -->
                        <table class="table table-sm mt-2" style="width:100%">
                            <tr>
                                <td style="width:35%"><strong>العميل / Client</strong></td>
                                <td><span t-field="o.client_id.name"/></td>
                                <td style="width:35%"><strong>المسؤول / Responsible</strong></td>
                                <td><span t-field="o.user_id.name"/></td>
                            </tr>
                            <tr>
                                <td><strong>رقم مرجعي للعميل / Client Ref.</strong></td>
                                <td><span t-field="o.client_reference"/></td>
                                <td><strong>الحالة / Status</strong></td>
                                <td><span t-field="o.state"/></td>
                            </tr>
                            <tr>
                                <td><strong>موعد التقديم / Submission Deadline</strong></td>
                                <td><span t-field="o.submission_deadline"/></td>
                                <td><strong>تاريخ الفتح / Opening Date</strong></td>
                                <td><span t-field="o.opening_date"/></td>
                            </tr>
                            <tr>
                                <td><strong>القيمة التقديرية / Estimated Value</strong></td>
                                <td><span t-field="o.estimated_value"/></td>
                                <td t-if="o.awarded_value"><strong>قيمة الترسية / Awarded Value</strong></td>
                                <td t-if="o.awarded_value"><span t-field="o.awarded_value"/></td>
                            </tr>
                            <tr t-if="o.date_won">
                                <td><strong>تاريخ الترسية / Award Date</strong></td>
                                <td colspan="3"><span t-field="o.date_won"/></td>
                            </tr>
                        </table>

                        <!-- Description -->
                        <h5 class="mt-3" t-if="o.description" style="color:#1a5276;">
                            وصف المناقصة / Description
                        </h5>
                        <p t-field="o.description"/>

                        <!-- BOQ Table -->
                        <div t-if="o.boq_line_ids">
                            <h5 class="mt-3" style="color:#1a5276;">
                                جدول الكميات / Bill of Quantities
                            </h5>
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr style="background-color:#1a5276; color:white;">
                                        <th>الكود / Code</th>
                                        <th>البيان / Description</th>
                                        <th>الوحدة / UoM</th>
                                        <th class="text-end">الكمية / Qty</th>
                                        <th class="text-end">سعر الوحدة / Unit Price</th>
                                        <th class="text-end">الإجمالي / Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="o.boq_line_ids" t-as="b">
                                        <td><span t-field="b.code"/></td>
                                        <td><span t-field="b.name"/></td>
                                        <td><span t-field="b.uom_id.name"/></td>
                                        <td class="text-end"><span t-field="b.quantity_contracted"/></td>
                                        <td class="text-end"><span t-field="b.unit_price"/></td>
                                        <td class="text-end"><span t-field="b.total_contracted"/></td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr style="background-color:#f8f9fa; font-weight:bold; border-top:2px solid #1a5276;">
                                        <td colspan="5">إجمالي القيمة التقديرية / Total Estimated Value</td>
                                        <td class="text-end"><span t-field="o.boq_total_contracted"/></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <!-- Footer -->
                        <div class="row mt-5 pt-5">
                            <div class="col-4 text-center">
                                <hr style="width:60%;"/>
                                <p>المُعِد / Prepared By</p>
                            </div>
                            <div class="col-4 text-center">
                                <hr style="width:60%;"/>
                                <p>المُراجع / Reviewed By</p>
                            </div>
                            <div class="col-4 text-center">
                                <hr style="width:60%;"/>
                                <p>المُعتمد / Approved By</p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

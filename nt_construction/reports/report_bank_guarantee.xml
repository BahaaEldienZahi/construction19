<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_bank_guarantee" model="ir.actions.report">
        <field name="name">ШӯЩҲШ§Ш© ШөЩ…Ш§ЩҶ ШЁЩҶЩғЩҠ / Bank Guarantee</field>
        <field name="model">bank.guarantee</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_bank_guarantee_document</field>
        <field name="report_file">nt_construction.report_bank_guarantee_document</field>
        <field name="print_report_name">'ШӯЩҲШ«Ш© ШөЩ…Ш§ЩҶ - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_bank_guarantee"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_bank_guarantee_document">
        <t t-call="web.html_container"><tt-foreach="docs" t-as="o"><t t-call="web.external_layout">
            <div class="page">
                <div class="text-center mb-3"><h2 style="color:#7d3c98; margin-bottom:0;">ШӯЩҲШ§Ш© ШөЩ…Ш§ЩҶ ШЁЩҶЩғЩҠ / Bank Guarantee</h2><h4 style="color:#7f8c8d;" t-field="o.name"/></div>
                <hr style="border-top:3px solid #7d3c98;"/>
                <table class="table table-sm mt-2" style="width:100%">
                    <tr><td style="width:35%"><strong>ЩҶЩҲШ№ Ш§Щ„Ш¶Щ…Ш§ЩҶ / Type</strong></td><td><span t-field="o.guarantee_type"/></td><td style="width:35%"><strong>Ш§Щ„Щ…М№ЩҶЩҠЩҠШҜ / Beneficiary</strong></td><td><span t-field="o.beneficiary_id.name"/></td></tr>
                    <tr><td><strong>Ш§Щ„Щ…ШҙШұЩҲШ№ / Project</strong></td><td><span t-field="o.project_id.name"/></td><td t-if="o.tender_id"><strong>Ш§Щ„Щ…Ш§ЩӮШҙШөШ© / Tender</strong></td><td t-if="o.tender_id"><span t-field="o.tender_id.name"/></td></tr>
                    <tr><td><strong>Ш§Щ„аШЁЩҶЩҶ Ш§Щ„Щ„Щ–ШөШ¬Шұ / Issuing Bank</strong></td><td><span t-field="o.bank_id.name"/> вҖ” <span t-field="o.bank_branch"/></td><td><strong>Ш§Щ„ШұЩӮЩ… Ш§Щ„Щ…ШұШ№ЩҠ Щ„Щ„ШӘЩҶЩҶ / Bank Ref.</strong></td><td><span t-field="o.reference_number"/></td></tr>
                    <tr><td><strong>Ш§Щ„Щ…ШөШҚЩ„ШЈ / Amount</strong></td><td><span t-field="o.amount"/></td><td><strong>Ш§ЩҶШіШЁШ© Щ…ЩҶ Ш§Щ„Ш№ЩӮШҜ / % of Contract</strong></td><td><span t-field="o.percentage"/>%</td></tr>
                    <tr><td><strong>ШӘШ§ШұЩҠШ® Ш§Щ„е…ШіШҜШ§Шұ / Issue Date</strong></td><td><span t-field="o.issue_date"/></td><td><strong>ШӘШ§ШұЩҠШ® Ш§Щ„Ш§ЩҶШ§ЩҲЩҲШ© / Expiry Date</strong></td><td><span t-att-style="'color:#c0392b; font-weight:bold;' if o.expiry_date and o.state in ('issued','extended') else ''" t-field="o.expiry_date"/></td></tr>
                    <tr t-if="o.claim_date"><td><strong>ШӘШ§ШұЩҠШ® Ш§Щ„Щ…ШөШ§Щ„Ш© / Claim Date</strong></td><td colspan="3"><span style="color:#c0392b;" t-field="o.claim_date"/></td></tr>
                    <tr><td><strong>Ш§Щ„ШӯШ§Щ„Ш© / Status</strong></td><td colspan="3"><span t-field="o.state"/></td></tr>
                </table>
                <h5 class="mt-3" t-if="o.notes" style="color:#7d3c98;">Щ…Ш§Ш¬Н…ЩҠШ§Ш© / Notes</h5>
                <p t-field="o.notes" style="background-color:#f4ecf7; padding:8px; border:1px solid #d7bde2; border-radius:4px;"/>
                <div class="row mt-5 pt-5"><div class="col-6 text-center"><hr style="width:60%;"/><p>Ш§Щ„Щ…ЩҸШ№ЩҗШҜ / Prepared By</p></div><div class="col-6 text-center"><hr style="width:60%;"/><p>Ш§Щ„Щ…ЩҸШұШ§Ш¬Ш№ / Reviewed By</p></div></div>
            </div>
        </t></t></t>
    </template>
</odoo>

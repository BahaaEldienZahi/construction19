<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_bank_guarantee" model="ir.actions.report">
        <field name="name">Bank Guarantee Summary</field>
        <field name="model">bank.guarantee</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_bank_guarantee_document</field>
        <field name="report_file">nt_construction.report_bank_guarantee_document</field>
        <field name="print_report_name">'Bank Guarantee - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_bank_guarantee"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_bank_guarantee_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h2>Bank Guarantee Summary</h2>
                                <h4 t-field="o.name"/>
                            </div>
                            <div class="text-end">
                                <span class="badge rounded-pill text-bg-light border" t-field="o.state"/>
                            </div>
                        </div>

                        <table class="table table-sm mt-3" style="width:65%">
                            <tr><td><strong>Type</strong></td><td><span t-field="o.guarantee_type"/></td></tr>
                            <tr><td><strong>Project</strong></td><td><span t-field="o.project_id.name"/></td></tr>
                            <tr t-if="o.tender_id"><td><strong>Tender</strong></td><td><span t-field="o.tender_id.name"/></td></tr>
                            <tr><td><strong>Beneficiary</strong></td><td><span t-field="o.beneficiary_id.name"/></td></tr>
                            <tr><td><strong>Issuing Bank</strong></td><td><span t-field="o.bank_id.name"/> <span t-field="o.bank_branch"/></td></tr>
                            <tr><td><strong>Reference No.</strong></td><td><span t-field="o.reference_number"/></td></tr>
                            <tr><td><strong>Amount</strong></td><td><span t-field="o.amount"/></td></tr>
                            <tr><td><strong>% of Contract</strong></td><td><span t-field="o.percentage"/></td></tr>
                            <tr><td><strong>Issue Date</strong></td><td><span t-field="o.issue_date"/></td></tr>
                            <tr><td><strong>Expiry Date</strong></td><td><span t-field="o.expiry_date"/></td></tr>
                            <tr t-if="o.claim_date"><td><strong>Claim Date</strong></td><td><span t-field="o.claim_date"/></td></tr>
                        </table>

                        <h5 class="mt-3" t-if="o.notes">Notes</h5>
                        <p t-field="o.notes"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

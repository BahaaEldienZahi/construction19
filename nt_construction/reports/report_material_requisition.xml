<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_material_requisition" model="ir.actions.report">
        <field name="name">طلب صـف مواد / Material Requisition</field>
        <field name="model">material.requisition</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_material_requisition_document</field>
        <field name="report_file">nt_construction.report_material_requisition_document</field>
        <field name="print_report_name">'طلب صـف مواد - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_material_requisition"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_material_requisition_document">
        <t t-call="web.html_container"><t t-foreach="docs" t-as="o"><t t-call="web.external_layout">
            <div class="page">
                <div class="text-center mb-3"><h2 style="color:#b7950b; margin-bottom:0;">طلب صفف مواد / Material Requisition</h2><h4 style="color:#7f8c8d;" t-field="o.name"/></div>
                <hr style="border-top:3px solid #b7950b;"/>
                <table class="table table-sm mt-2" style="width:100%">
                    <tr><td style="width:30%"><strong>المشروع / Project</strong></td><td><span t-field="o.project_id.name"/></td><td style="width:30%"><strong>التاريخ / Date</strong></td><td><span t-field="o.date"/></td></tr>
                    <tr><td><strong>الطالب / Requested By</strong></td><td><span t-field="o.requested_by.name"/></td><td><strong>الحالة / Status</strong></td><td><span t-field="o.state"/></td></tr>
                </table>
                <h5 class="mt-3" style="color:#b7950b;">المواد الملطوبة / Requested Materials</h5>
                <table class="table table-sm table-bordered mt-2">
                    <thead><tr style="background-color:#b7950b; color:white;"><th>البيان / Description</th><th>الوحدة / UoM</th><th class="text-end">الكمية المطوبية / Qty Requested</th><th class="text-end">الكمية المستومة / Qty Delivered</th><th class="text-end">المتبقي / Remaining</th><th>حالة التسيم / Delivery</th></tr></thead>
                    <tbody><tr t-foreach="o.line_ids" t-as="line"><td><span t-field="line.description"/></td><td><span t-field="line.uom_id.name"/></td><td class="text-end"><span t-field="line.quantity_requested"/></td><td class="text-end"><span t-field="line.quantity_delivered"/></td><td class="text-end"><span t-att-style="'color:#c0392b; font-weight:bold;' if line.quantity_remaining > 0 else 'color:#27ae60;'" t-field="line.quantity_remaining"/></td><td><span t-att-style="'color:#27ae60;' if line.delivery_status == 'complete' else 'color:#f39c12;' if line.delivery_status == 'partial' else 'color:#c0392b;'" t-field="line.delivery_status"/></td></tr></tbody>
                </table>
                <h5 class="mt-3" t-if="o.notes" style="color:#b7950b;">ماجͅياة / Notes</h5>
                <p t-field="o.notes" style="background-color:#fef9e7; padding:8px; border:1px solid #f9e79f; border-radius:4px;"/>
                <div class="row mt-5 pt-5"><div class="col-4 text-center"><hr style="width:60%;"/><p>الطالب / Requested By</p></div><div class="col-4 text-center"><hr style="width:60%;"/><p>أمئ، اللسنن / Store Keeper</p></div><div class="col-4 text-center"><hr style="width:60%;"/><p>المُعتمد / Approved By</p></div></div>
            </div>
        </t></t></t>
    </template>
</odoo>

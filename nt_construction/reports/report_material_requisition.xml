<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_material_requisition" model="ir.actions.report">
        <field name="name">Material Requisition</field>
        <field name="model">material.requisition</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_material_requisition_document</field>
        <field name="report_file">nt_construction.report_material_requisition_document</field>
        <field name="print_report_name">'Material Requisition - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_material_requisition"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_material_requisition_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h2>Material Requisition</h2>
                                <h4 t-field="o.name"/>
                            </div>
                            <div class="text-end">
                                <span class="badge rounded-pill text-bg-light border" t-field="o.state"/>
                            </div>
                        </div>

                        <table class="table table-sm mt-3" style="width:65%">
                            <tr><td><strong>Project</strong></td><td><span t-field="o.project_id.name"/></td></tr>
                            <tr><td><strong>Date</strong></td><td><span t-field="o.date"/></td></tr>
                            <tr><td><strong>Requested By</strong></td><td><span t-field="o.requested_by.name"/></td></tr>
                        </table>

                        <table class="table table-sm table-bordered mt-3">
                            <thead>
                                <tr class="table-active">
                                    <th>Description</th>
                                    <th>UoM</th>
                                    <th class="text-end">Qty Requested</th>
                                    <th class="text-end">Qty Delivered</th>
                                    <th class="text-end">Qty Remaining</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.line_ids" t-as="line">
                                    <td><span t-field="line.description"/></td>
                                    <td><span t-field="line.uom_id.name"/></td>
                                    <td class="text-end"><span t-field="line.quantity_requested"/></td>
                                    <td class="text-end"><span t-field="line.quantity_delivered"/></td>
                                    <td class="text-end"><span t-field="line.quantity_remaining"/></td>
                                    <td><span t-field="line.delivery_status"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <h5 class="mt-3" t-if="o.notes">Notes</h5>
                        <p t-field="o.notes"/>

                        <div class="row mt-5 pt-5">
                            <div class="col-4 text-center"><p>Requested By</p></div>
                            <div class="col-4 text-center"><p>Store Keeper</p></div>
                            <div class="col-4 text-center"><p>Approved By</p></div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

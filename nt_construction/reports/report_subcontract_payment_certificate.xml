<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_subcontract_payment_certificate" model="ir.actions.report">
        <field name="name">مستخلص مقاول باطن / Subcontractor Payment Certificate</field>
        <field name="model">subcontract.payment.certificate</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">nt_construction.report_subcontract_payment_certificate_document</field>
        <field name="report_file">nt_construction.report_subcontract_payment_certificate_document</field>
        <field name="print_report_name">'مستخلص مقاول باطن - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_subcontract_payment_certificate"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_subcontract_payment_certificate_document">
        <t t-call="web.html_container"><t t-foreach="docs" t-as="o"><t t-call="web.external_layout">
            <div class="page">
                <div class="text-center mb-3"><h2 style="color:#8e44ad; margin-bottom:0;">مستخلص مقاول باطن / Subcontractor Payment Certificate</h2><h4 style="color:#7f8c8d;" t-field="o.name"/></div>
                <hr style="border-top:3px solid #8e44ad;"/>
                <table class="table table-sm mt-2" style="width:100%">
                    <tr><td style="width:30%"><strong>المشروع / Project</strong></td><td><span t-field="o.project_id.name"/></td><td style="width:30%"><strong>مقاول الباطن / Subcontractor</strong></td><td><span t-field="o.partner_id.name"/></td></tr>
                    <tr><td><strong>الاتفاقية / Agreement</strong></td><td><span t-field="o.subcontract_agreement_id.name"/></td><td><strong>التاريخ / Date</strong></td><td><span t-field="o.date"/></td></tr>
                    <tr t-if="o.period_from or o.period_to"><td><strong>الفتسة / Period</strong></td><td colspan="3"><span t-field="o.period_from"/> — <span t-field="o.period_to"/></td></tr>
                    <tr><td><strong>الحالة / Status</strong></td><td colspan="3"><span t-field="o.state"/></td></tr>
                </table>
                <h5 class="mt-3" style="color:#8e44ad;">بنود المستخلص / Certificate Lines</h5>
                <table class="table table-sm table-bordered mt-2">
                    <thead><tr style="background-color:#8e44ad; color:white;"><th>البند / BOQ Item</th><th class="text-end">سعر الوحدة / Unit Price</th><th class="text-end">كمية المستخلص / Qty This Period</th><th class="text-end">المبلغ / Amount</th></tr></thead>
                    <tbody><tr t-foreach="o.line_ids" t-as="line"><td><small t-field="line.boq_line_id.code"/> — <span t-field="line.boq_line_id.name"/></td><td class="text-end"><span t-field="line.unit_price"/></td><td class="text-end"><span t-field="line.quantity_this_period"/></td><td class="text-end"><span t-field="line.amount_this_period"/></td></tr></tbody>
                </table>
                <div class="row mt-3"><div class="col-6 offset-6"><table class="table table-sm" style="font-size:13px;">
                    <tr><td>إجمالي المستخلص / Gross Amount</td><td class="text-end"><span t-field="o.gross_amount"/></td></tr>
                    <tr><td>خصم الضمان / Retention (<span t-field="o.retention_percentage"/>%)</td><td class="text-end" style="color:#c0392b;">- <span t-field="o.retention_amount"/></td></tr>
                    <tr style="background-color:#f4ecf7; font-weight:bold; border-top:2px solid #8e44ad;"><td>صافي المصافي السيحق / Net Payable</td><td class="text-end" style="font-size:15px; color:#8e44ad;"><span t-field="o.net_payable"/></td></tr>
                </table></div></div>
                <div class="row mt-5 pt-5"><div class="col-4 text-center"><hr style="width:60%;"/><p>المُعِد / Prepared By</p></div><div class="col-4 text-center"><hr style="width:60%;"/><p>المُراجع (L1) / Reviewed By</p><p t-if="o.approver_l1_id" style="font-size:12px;" t-field="o.approver_l1_id.name"/></div><div class="col-4 text-center"><hr style="width:60%;"/><p>المُعتمد (<i> La </i>2) / Approved By</p><p t-if="o.approver_l2_id" style="font-size:12px;" t-field="o.approver_l2_id.name"/></div></div>
            </div>
        </t></t></t>
    </template>
</odoo>

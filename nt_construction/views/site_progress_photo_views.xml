<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ SITE PROGRESS PHOTOS ============ -->

    <record id="view_site_progress_photo_kanban" model="ir.ui.view">
        <field name="name">site.progress.photo.kanban</field>
        <field name="model">site.progress.photo</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" string="Progress Photos">
                <field name="image"/>
                <field name="name"/>
                <field name="date"/>
                <field name="project_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_image">
                                <img t-att-src="'data:image/png;base64,' + record.image.raw_value"
                                     style="width:100%; height:180px; object-fit:cover;"
                                     t-if="record.image.raw_value"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><field name="date"/></div>
                                <div><field name="location"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_site_progress_photo_form" model="ir.ui.view">
        <field name="name">site.progress.photo.form</field>
        <field name="model">site.progress.photo</field>
        <field name="arch" type="xml">
            <form string="Progress Photo">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="date"/>
                            <field name="taken_by"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="image" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags"/>
                        <field name="boq_line_ids" widget="many2many_tags"/>
                        <field name="daily_report_id"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="وصف الصورة..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_site_progress_photo_list" model="ir.ui.view">
        <field name="name">site.progress.photo.list</field>
        <field name="model">site.progress.photo</field>
        <field name="arch" type="xml">
            <list string="Progress Photos">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="location"/>
                <field name="taken_by" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_site_progress_photo_search" model="ir.ui.view">
        <field name="name">site.progress.photo.search</field>
        <field name="model">site.progress.photo</field>
        <field name="arch" type="xml">
            <search string="Search Photos">
                <field name="name"/>
                <field name="project_id"/>
                <field name="location"/>
                <field name="tag_ids"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_site_progress_photo" model="ir.actions.act_window">
        <field name="name">Progress Photos</field>
        <field name="res_model">site.progress.photo</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>

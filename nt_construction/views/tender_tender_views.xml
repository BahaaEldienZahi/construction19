<?xml version="1.0" encoding="utf-8"?>
<odoo>

    Form View
    <record id="view_tender_tender_form" model="ir.ui.view">
        <field name="name">tender.tender.form</field>
        <field name="model">tender.tender</field>
        <field name="arch" type="xml">
            <form string="Tender">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_under_evaluation" string="Move to Evaluation" type="object"
                            class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_set_won" string="Mark as Won" type="object"
                            class="btn-success" invisible="state not in ('submitted', 'under_evaluation')"/>
                    <button name="action_set_lost" string="Mark as Lost" type="object"
                            invisible="state not in ('submitted', 'under_evaluation')"/>
                    <button name="action_create_project" string="Create Execution Project" type="object"
                            class="btn-success" invisible="state != 'won' or project_id"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('cancelled', 'won')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('lost', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,under_evaluation,won"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_project" type="object"
                                class="oe_stat_button" icon="fa-folder-open"
                                invisible="not project_id">
                            <field name="project_count" widget="statinfo" string="Project"/>
                        </button>
                        <button name="action_view_boq" type="object"
                                class="oe_stat_button" icon="fa-list-ol">
                            <field name="boq_line_count" widget="statinfo" string="BOQ Lines"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="client_id"/>
                            <field name="client_reference"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="submission_deadline"/>
                            <field name="opening_date"/>
                            <field name="date_won" invisible="not date_won"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="estimated_value"/>
                            <field name="boq_total_contracted"/>
                        </group>
                        <group>
                            <field name="awarded_value" invisible="state not in ('under_evaluation', 'won', 'lost')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="تفاصيل المناقصة، نطاق العمل، الشروط..."/>
                        </page>
                        <page string="Lost / Cancel Reason"
                              invisible="state not in ('lost', 'cancelled')">
                            <field name="lost_reason" invisible="state != 'lost'"
                                   placeholder="سبب خسارة المناقصة..."/>
                            <field name="cancel_reason" invisible="state != 'cancelled'"
                                   placeholder="سبب الإلغاء..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    List View
    <record id="view_tender_tender_list" model="ir.ui.view">
        <field name="name">tender.tender.list</field>
        <field name="model">tender.tender</field>
        <field name="arch" type="xml">
            <list string="Tenders" decoration-success="state == 'won'"
                  decoration-danger="state == 'lost'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="client_id"/>
                <field name="submission_deadline"/>
                <field name="estimated_value" sum="Total Estimated"/>
                <field name="user_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'won'"
                       decoration-danger="state == 'lost'"
                       decoration-info="state in ('submitted', 'under_evaluation')"/>
            </list>
        </field>
    </record>

    Search View
    <record id="view_tender_tender_search" model="ir.ui.view">
        <field name="name">tender.tender.search</field>
        <field name="model">tender.tender</field>
        <field name="arch" type="xml">
            <search string="Search Tenders">
                <field name="name"/>
                <field name="client_id"/>
                <field name="client_reference"/>
                <filter string="My Tenders" name="my_tenders" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Won" name="won" domain="[('state', '=', 'won')]"/>
                <filter string="Lost" name="lost" domain="[('state', '=', 'lost')]"/>
                <group>
                    <filter string="Client" name="group_client"
                            context="{'group_by': 'client_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Responsible" name="group_user"
                            context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    Action
    <record id="action_tender_tender" model="ir.actions.act_window">
        <field name="name">Tenders</field>
        <field name="res_model">tender.tender</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_tenders': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                أنشئ أول مناقصة
            </p>
        </field>
    </record>

    Menu (menu_tender_root is defined in menu_structure.xml, loaded earlier)
    <menuitem id="menu_tender_tender" name="Tenders" parent="menu_tender_management"
              action="action_tender_tender" sequence="10"/>
    <menuitem id="menu_boq_line" name="Bill of Quantities" parent="menu_tender_management"
              action="nt_construction.action_boq_line" sequence="20"/>

</odoo>

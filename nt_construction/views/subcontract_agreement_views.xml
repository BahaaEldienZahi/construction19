<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Subcontract Agreement Tree View -->
    <record id="view_subcontract_agreement_tree" model="ir.ui.view">
        <field name="name">subcontract.agreement.tree</field>
        <field name="model">subcontract.agreement</field>
        <field name="arch" type="xml">
            <tree string="Subcontract Agreements">
                <field name="name"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="contract_value"/>
                <field name="total_value" sum="Total"/>
                <field name="total_executed_value" sum="Executed"/>
                <field name="execution_percentage_total" widget="progressbar"/>
                <field name="state" widget="badge" decoration-info="state=='draft'" decoration-success="state=='approved'" decoration-danger="state=='rejected'"/>
            </tree>
        </field>
    </record>

    <!-- Subcontract Agreement Form View -->
    <record id="view_subcontract_agreement_form" model="ir.ui.view">
        <field name="name">subcontract.agreement.form</field>
        <field name="model">subcontract.agreement</field>
        <field name="arch" type="xml">
            <form string="Subcontract Agreement">
                <header>
                    <button name="action_submit_for_approval" string="Submit for Approval" type="object" states="draft" class="btn-primary"/>
                    <button name="action_approve_l1" string="Approve Level 1" type="object" states="submitted" class="btn-primary"/>
                    <button name="action_approve_l2" string="Approve Level 2" type="object" states="approved_l1" class="btn-primary"/>
                    <button name="action_reject" string="Reject" type="object" states="submitted,approved_l1" class="btn-danger"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" states="submitted,approved_l1,approved,rejected"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="completion_date"/>
                            <field name="retention_percentage"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="contract_value"/>
                            <field name="execution_percentage_total" widget="progressbar"/>
                            <field name="total_executed_value"/>
                        </group>
                    </group>
                    <group string="Scope of Work">
                        <field name="scope_of_work" nolabel="1"/>
                    </group>
                    <group string="Agreement Lines">
                        <field name="line_ids">
                            <tree editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="boq_line_id"/>
                                <field name="code"/>
                                <field name="name"/>
                                <field name="uom_id"/>
                                <field name="quantity"/>
                                <field name="unit_price"/>
                                <field name="subtotal"/>
                                <field name="executed_qty"/>
                                <field name="execution_percentage" widget="progressbar"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Subcontract Agreement Search View -->
    <record id="view_subcontract_agreement_search" model="ir.ui.view">
        <field name="name">subcontract.agreement.search</field>
        <field name="model">subcontract.agreement</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <filter string="Draft" name="draft" domain="['state','=','draft']"/>
                <filter string="Submitted" name="submitted" domain="['state','=','submitted']"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by':'project_id'}"/>
                    <filter string="Subcontractor" name="group_partner" context="{'group_by':'partner_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'onds'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_subcontract_agreement" model="ir.actions.act_window">
        <field name="name">Subcontract Agreements</field>
        <field name="res_model">subcontract.agreement</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_subcontract_agreement" name="Subcontract Agreements"
              parent="nt_construction.menu_commercial"
              action="action_subcontract_agreement" sequence="4"/>

</odoo>

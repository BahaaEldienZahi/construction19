    <!-- Form View -->
    <record id="view_subcontract_agreement_form" model="ir.ui.view">
        <field name="name">subcontract.agreement.form</field>
        <field name="model">subcontract.agreement</field>
        <field name="arch" type="xml">

            <form string="Subcontract Agreement">

                <header>

                    <!-- Submit -->
                    <button name="action_submit_for_approval"
                            string="Submit For Approval"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>


                    <!-- Level 1 Approval -->
                    <button name="action_approve_l1"
                            string="Approve Level 1"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'submitted'"/>


                    <!-- Final Approval -->
                    <button name="action_approve_l2"
                            string="Final Approve"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'approved_l1'"/>


                    <!-- Reject -->
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ['submitted','approved_l1']"/>


                    <!-- Cancel -->
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'approved'"/>


                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,approved_l1,approved,rejected,cancelled"/>

                </header>


                <sheet>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>


                    <group>

                        <group>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="date"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>


                        <group>
                            <field name="contract_value"/>
                            <field name="total_value"/>
                            <field name="retention_percentage"/>
                        </group>

                    </group>


                    <group string="Contract Period">

                        <field name="start_date"/>
                        <field name="completion_date"/>

                    </group>



                    <notebook>


                        <page string="Scope Of Work">

                            <field name="scope_of_work"
                                   placeholder="Enter scope of work..."/>

                        </page>



                        <page string="BOQ Lines">

                            <field name="line_ids">

                                <list editable="bottom">

                                    <field name="boq_line_id"/>

                                    <field name="code"/>

                                    <field name="name"/>

                                    <field name="uom_id"/>

                                    <field name="quantity"/>

                                    <field name="unit_price"/>

                                    <field name="subtotal"
                                           readonly="1"/>

                                </list>

                            </field>


                            <group class="oe_subtotal_footer oe_right">

                                <field name="total_value"
                                       readonly="1"/>

                            </group>


                        </page>


                    </notebook>


                </sheet>


                <chatter/>

            </form>

        </field>
    </record>




    <!-- Action -->
    <record id="action_subcontract_agreement" model="ir.actions.act_window">

        <field name="name">Subcontract Agreements</field>
        <field name="res_model">subcontract.agreement</field>

        <field name="view_mode">list,form</field>

    </record>

    <menuitem
            id="menu_subcontract_root"
            name="Subcontracting"
            parent="nt_construction.menu_tender_root"
            sequence="50"/>


    <menuitem
            id="menu_subcontract_agreement"
            name="Agreements"
            parent="menu_subcontract_root"
            action="action_subcontract_agreement"
            sequence="10"/>



</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard: Load Certificate from Work Measurement -->
    <record id="view_load_certificate_from_wm_wizard_form" model="ir.ui.view">
        <field name="name">load.certificate.from.wm.wizard.form</field>
        <field name="model">load.certificate.from.wm.wizard</field>
        <field name="arch" type="xml">
            <form string="Load from Work Measurement">
                <group>
                    <field name="work_measurement_id"/>
                    <field name="measurement_total" readonly="1"/>
                </group>
                <footer>
                    <button name="action_load" string="Load Lines" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

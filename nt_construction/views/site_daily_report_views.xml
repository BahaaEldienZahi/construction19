<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Site Daily Report Tree View -->
    <record id="view_site_daily_report_tree" model="ir.ui.view">
        <field name="name">site.daily.report.tree</field>
        <field name="model">site.daily.report</field>
        <field name="arch" type="xml">
            <tree string="Site Daily Reports" default_order="date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="weather"/>
                <field name="total_manpower_count"/>
                <field name="total_equipment_hours"/>
                <field name="total_amount_executed_today"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- Site Daily Report Form View -->
    <record id="view_site_daily_report_form" model="ir.ui.view">
        <field name="name">site.daily.report.form</field>
        <field name="model">site.daily.report</field>
        <field name="arch" type="xml">
            <form string="Site Daily Report (Sarky)">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" states="draft" class="btn-primary"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" states="confirmed"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="date"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="weather"/>
                        </group>
                    </group>

                    <group string="Manpower">
                        <field name="manpower_ids">
                            <tree editable="bottom">
                                <field name="trade"/>
                                <field name="subcontract_agreement_id"/>
                                <field name="headcount"/>
                                <field name="planned_headcount"/>
                                <field name="headcount_variance"/>
                                <field name="hours"/>
                                <field name="note"/>
                            </tree>
                        </field>
                    </group>

                    <group string="Equipment">
                        <field name="equipment_ids">
                            <tree editable="bottom">
                                <field name="equipment_name"/>
                                <field name="equipment_type"/>
                                <field name="count"/>
                                <field name="hours_worked"/>
                                <field name="hours_idle"/>
                                <field name="idle_reason"/>
                            </tree>
                        </field>
                    </group>

                    <group string="Site Notes / Issues">
                        <field name="site_notes" nolabel="1"/>
                    </group>

                    <group string="Progress">
                        <field name="progress_ids">
                            <tree editable="bottom">
                                <field name="boq_line_id"/>
                                <field name="quantity_executed"/>
                                <field name="hours_worked"/>
                                <field name="cost"/>
                                <field name="notes"/>
                            </tree>
                        </field>
                        <group>
                            <field name="total_amount_executed_today"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Site Daily Report Search View -->
    <record id="view_site_daily_report_search" model="ir.ui.view">
        <field name="name">site.daily.report.search</field>
        <field name="model">site.daily.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="project_id"/>
                <field name="date"/>
                <field name="user_id"/>
                <filter string="Draft" name="draft" domain="['state','=','draft']"/>
                <filter string="Confirmed" name="confirmed" domain="['state','=','confirmed']"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by':'project_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_site_daily_report" model="ir.actions.act_window">
        <field name="name">Daily Reports (Sarky)</field>
        <field name="res_model">site.daily.report</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_site_daily_report" name="Daily Reports (Sarky)"
              parent="nt_construction.menu_project_execution"
              action="action_site_daily_report" sequence="2"/>

</odoo>

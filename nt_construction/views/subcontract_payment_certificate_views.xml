<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ SUBCONTRACTOR PAYMENT CERTIFICATE ============ -->

    <record id="view_subcontract_payment_certificate_form" model="ir.ui.view">
        <field name="name">subcontract.payment.certificate.form</field>
        <field name="model">subcontract.payment.certificate</field>
        <field name="arch" type="xml">
            <form string="Subcontractor Payment Certificate">
                <header>
                    <button name="action_submit_for_approval" string="Submit for Approval" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve_l1" string="Approve (L1)" type="object"
                            class="btn-primary" invisible="state != 'submitted'"
                    />
                    <button name="action_approve_l2" string="Final Approve (L2)" type="object"
                            class="btn-success" invisible="state != 'approved_l1'"
                    />
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state not in ('submitted', 'approved_l1')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'rejected'"/>
                    <button name="action_create_vendor_bill" string="Create Vendor Bill" type="object"
                            class="btn-success" invisible="state != 'approved' or move_id"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved_l1,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="subcontract_agreement_id" readonly="state != 'draft'"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="period_from"/>
                            <field name="period_to"/>
                            <field name="gross_amount"/>
                            <field name="retention_percentage" readonly="1"/>
                            <field name="retention_amount"/>
                            <field name="net_payable"/>
                        </group>
                    </group>
                    <field name="line_ids" readonly="state != 'draft'">
                        <list editable="bottom">
                            <field name="boq_line_id"/>
                            <field name="unit_price" readonly="1"/>
                            <field name="quantity_this_period"/>
                            <field name="amount_this_period" sum="Total"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_subcontract_payment_certificate_list" model="ir.ui.view">
        <field name="name">subcontract.payment.certificate.list</field>
        <field name="model">subcontract.payment.certificate</field>
        <field name="arch" type="xml">
            <list string="Subcontractor Payment Certificates" decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="subcontract_agreement_id"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="gross_amount" sum="Gross"/>
                <field name="net_payable" sum="Net"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"
                       decoration-info="state in ('submitted', 'approved_l1')"/>
            </list>
        </field>
    </record>

    <record id="view_subcontract_payment_certificate_search" model="ir.ui.view">
        <field name="name">subcontract.payment.certificate.search</field>
        <field name="model">subcontract.payment.certificate</field>
        <field name="arch" type="xml">
            <search string="Search Subcontractor Payment Certificates">
                <field name="name"/>
                <field name="subcontract_agreement_id"/>
                <field name="partner_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Pending Approval" name="pending"
                        domain="[('state', 'in', ('submitted', 'approved_l1'))]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Subcontractor" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_subcontract_payment_certificate" model="ir.actions.act_window">
        <field name="name">Subcontractor Payment Certificates</field>
        <field name="res_model">subcontract.payment.certificate</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_subcontract_payment_certificate" name="Subcontractor Certificates"
              parent="menu_commercial"
              action="action_subcontract_payment_certificate" sequence="40"/>

</odoo>

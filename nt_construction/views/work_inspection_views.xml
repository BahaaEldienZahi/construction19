<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ WORK INSPECTION (WIR / MIR) ============ -->

    <record id="view_work_inspection_form" model="ir.ui.view">
        <field name="name">work.inspection.form</field>
        <field name="model">work.inspection</field>
        <field name="arch" type="xml">
            <form string="Work Inspection (WIR/MIR)">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_inspect" string="Record Inspection" type="object"
                            class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success" invisible="state != 'inspected'"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state != 'inspected'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('approved', 'rejected')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,inspected,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="inspection_type"/>
                            <field name="date"/>
                            <field name="inspection_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="inspector_id"/>
                            <field name="is_conforming" invisible="state not in ('inspected', 'approved', 'rejected')"/>
                            <field name="location"/>
                        </group>
                    </group>
                    <group string="Scope of Work to Inspect">
                        <field name="description" nolabel="1" placeholder="وصف الأعمال المطلوب فحصها..."/>
                    </group>
                    <field name="boq_line_ids" widget="many2many_tags" readonly="state != 'draft'"/>
                    <group string="Inspection Result" invisible="state not in ('inspected', 'approved', 'rejected')">
                        <field name="inspection_result" nolabel="1" placeholder="نتيجة الفحص..."/>
                    </group>
                    <group string="Rejection Reason" invisible="state != 'rejected'">
                        <field name="rejection_reason" nolabel="1" placeholder="سبب الرفض..."/>
                    </group>
                    <field name="attachment_ids" widget="many2many_binary" string="Attachments"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_work_inspection_list" model="ir.ui.view">
        <field name="name">work.inspection.list</field>
        <field name="model">work.inspection</field>
        <field name="arch" type="xml">
            <list string="Work Inspections" decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'" decoration-info="state == 'submitted'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="inspection_type"/>
                <field name="inspection_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"
                       decoration-info="state == 'submitted'"/>
            </list>
        </field>
    </record>

    <record id="view_work_inspection_search" model="ir.ui.view">
        <field name="name">work.inspection.search</field>
        <field name="model">work.inspection</field>
        <field name="arch" type="xml">
            <search string="Search Inspections">
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Pending" name="pending" domain="[('state', 'in', ('draft', 'submitted'))]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'inspection_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_work_inspection" model="ir.actions.act_window">
        <field name="name">Work Inspections</field>
        <field name="res_model">work.inspection</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

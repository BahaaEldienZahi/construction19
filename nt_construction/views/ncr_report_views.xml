<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ncr_report_tree" model="ir.ui.view">
        <field name="name">ncr.report.tree</field>
        <field name="model">ncr.report</field>
        <field name="arch" type="xml">
            <tree string="NCR / Non-Conformance" default_order="reported_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="severity" widget="badge"
                       decoration-danger="severity=='critical'"
                       decoration-warning="severity=='major'"/>
                <field name="description" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state=='closed'"
                       decoration-warning="state in ('open','investigation','corrective_action')"/>
                <field name="reported_date"/>
                <field name="responsible_id" optional="hide"/>
                <field name="closure_date" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_ncr_report_form" model="ir.ui.view">
        <field name="name">ncr.report.form</field>
        <field name="model">ncr.report</field>
        <field name="arch" type="xml">
            <form string="NCR Report">
                <header>
                    <button name="action_open" string="Open" type="object"
                            states="draft" class="btn-primary"/>
                    <button name="action_investigate" string="Investigate" type="object"
                            states="open"/>
                    <button name="action_corrective" string="Corrective Action" type="object"
                            states="investigation"/>
                    <button name="action_verify" string="Verify" type="object"
                            states="corrective_action"/>
                    <button name="action_close" string="Close" type="object"
                            states="verified" class="btn-primary"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            states="open,investigation,corrective_action"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="inspection_id"/>
                            <field name="severity"/>
                        </group>
                        <group>
                            <field name="reported_date"/>
                            <field name="reporter_id"/>
                            <field name="responsible_id"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Investigation">
                        <field name="root_cause" nolabel="1" placeholder="Root cause analysis..."/>
                    </group>
                    <group string="Actions">
                        <field name="corrective_action" nolabel="1" placeholder="Corrective action taken..."/>
                        <field name="preventive_action" nolabel="1" placeholder="Preventive action to avoid recurrence..."/>
                    </group>
                    <group>
                        <group>
                            <field name="closure_date"/>
                            <field name="verified_by"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_ncr_report_search" model="ir.ui.view">
        <field name="name">ncr.report.search</field>
        <field name="model">ncr.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="project_id"/>
                <field name="description"/>
                <filter string="Open" name="open" domain="[('state','!=','closed')]"/>
                <filter string="Critical" name="critical" domain="[('severity','=','critical')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by':'project_id'}"/>
                    <filter string="Severity" name="group_severity" context="{'group_by':'userity'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ncr_report" model="ir.actions.act_window">
        <field name="name">NCR / Non-Conformance</field>
        <field name="res_model">ncr.report</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_ncr_report" name="NCR / Non-Conformance"
              parent="nt_construction.menu_project_execution" sequence="55"
              action="action_ncr_report"/>

</odoo>

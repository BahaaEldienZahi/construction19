<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ MATERIAL REQUISITION ============ -->

    <record id="view_material_requisition_form" model="ir.ui.view">
        <field name="name">material.requisition.form</field>
        <field name="model">material.requisition</field>
        <field name="arch" type="xml">
            <form string="Material Requisition">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success" invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('approved', 'rejected')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,fully_delivered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="date"/>
                            <field name="requested_by"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="line_ids" readonly="state != 'draft'">
                        <list editable="bottom">
                            <field name="boq_line_id"/>
                            <field name="product_id"/>
                            <field name="description"/>
                            <field name="uom_id"/>
                            <field name="quantity_requested"/>
                            <field name="quantity_delivered" readonly="state == 'draft'"/>
                            <field name="quantity_remaining" readonly="1"/>
                            <field name="delivery_status" widget="badge"
                                   decoration-success="delivery_status == 'complete'"
                                   decoration-warning="delivery_status == 'partial'"
                                   decoration-danger="delivery_status == 'pending'"/>
                        </list>
                    </field>
                    <group string="Notes" invisible="state == 'draft'">
                        <field name="notes" nolabel="1" placeholder="ملاحظات..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_material_requisition_list" model="ir.ui.view">
        <field name="name">material.requisition.list</field>
        <field name="model">material.requisition</field>
        <field name="arch" type="xml">
            <list string="Material Requisitions" decoration-success="state == 'fully_delivered'"
                  decoration-info="state == 'approved'" decoration-muted="state == 'rejected'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="requested_by" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'fully_delivered'"
                       decoration-info="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_material_requisition_search" model="ir.ui.view">
        <field name="name">material.requisition.search</field>
        <field name="model">material.requisition</field>
        <field name="arch" type="xml">
            <search string="Search Requisitions">
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Delivered" name="delivered" domain="[('state', 'in', ('partially_delivered', 'fully_delivered'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_material_requisition" model="ir.actions.act_window">
        <field name="name">Material Requisitions</field>
        <field name="res_model">material.requisition</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_project_handover_form" model="ir.ui.view">
        <field name="name">project.handover.form</field>
        <field name="model">project.handover</field>
        <field name="arch" type="xml">
            <form string="Project Handover">
                <header>
                    <button name="action_confirm_provisional_handover" string="Confirm Provisional" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_release_retention_stage1" string="Release Stage 1 (50%)" type="object"
                            class="btn-info" invisible="state != 'provisional' or retention_release_stage1_done"/>
                    <button name="action_final_handover" string="Finalize Handover" type="object"
                            class="btn-success" invisible="state != 'provisional'"/>
                    <button name="action_release_retention_stage2" string="Release Stage 2 (50%)" type="object"
                            class="btn-info" invisible="state != 'final' or retention_release_stage2_done"/>
                    <button name="action_close" string="Close Project" type="object"
                            class="btn-success" invisible="state != 'final'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            class="btn-secondary" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,provisional,final,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="punch_list_open_count" readonly="1"/>
                            <field name="punch_list_total_count" readonly="1"/>
                            <field name="retention_held_total" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Provisional Handover">
                            <group>
                                <group>
                                    <field name="provisional_handover_date"/>
                                    <field name="defects_liability_months"/>
                                    <field name="defects_liability_end_date" readonly="1"/>
                                </group>
                                <group>
                                    <field name="retention_release_stage1_percentage"/>
                                    <field name="retention_release_stage1_amount" readonly="1"/>
                                    <field name="retention_release_stage1_date" readonly="1"/>
                                    <field name="retention_release_stage1_done" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Punch List">
                            <field name="punch_list_ids">
                                <list editable="bottom" decoration-danger="status == 'open'">
                                    <field name="description"/>
                                    <field name="location"/>
                                    <field name="responsible_party"/>
                                    <field name="date_reported" readonly="1"/>
                                    <field name="status" widget="badge" decoration-danger="status == 'open'" decoration-success="status == 'closed'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Final Handover">
                            <group>
                                <group>
                                    <field name="final_handover_date"/>
                                </group>
                                <group>
                                    <field name="retention_release_stage2_percentage"/>
                                    <field name="retention_release_stage2_amount" readonly="1"/>
                                    <field name="retention_release_stage2_date" readonly="1"/>
                                    <field name="retention_release_stage2_done" readonly="1"/>
                                </group>
                            </group>
                            <field name="final_acceptance_notes" nolabel="1" placeholder="Final acceptance notes..."/>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_project_handover_list" model="ir.ui.view">
        <field name="name">project.handover.list</field>
        <field name="model">project.handover</field>
        <field name="arch" type="xml">
            <list string="Project Handovers" decoration-success="state == 'closed'"
                  decoration-info="state in ('provisional', 'final')">
                <field name="name"/>
                <field name="project_id"/>
                <field name="provisional_handover_date"/>
                <field name="final_handover_date"/>
                <field name="punch_list_open_count" optional="show"/>
                <field name="retention_held_total" sum="Total Retained" optional="show"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>


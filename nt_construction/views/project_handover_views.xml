<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ PROJECT HANDOVER ============ -->

    <record id="view_project_handover_form" model="ir.ui.view">
        <field name="name">project.handover.form</field>
        <field name="model">project.handover</field>
        <field name="arch" type="xml">
            <form string="Project Handover">
                <header>
                    <button name="action_confirm_provisional_handover" string="Confirm Provisional Handover"
                            type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_release_retention_stage1" string="Release Retention (Stage 1)"
                            type="object" class="btn-warning"
                            invisible="state != 'provisional' or retention_release_stage1_done"/>
                    <button name="action_final_handover" string="Confirm Final Handover"
                            type="object" class="btn-success" invisible="state != 'provisional'"/>
                    <button name="action_release_retention_stage2" string="Release Retention (Stage 2)"
                            type="object" class="btn-warning"
                            invisible="state != 'final' or retention_release_stage2_done"/>
                    <button name="action_close" string="Close Project" type="object"
                            class="btn-success" invisible="state != 'final'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('draft', 'provisional')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,provisional,final,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="date"/>
                            <field name="provisional_handover_date"/>
                            <field name="defects_liability_months"/>
                            <field name="defects_liability_end_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="retention_held_total" readonly="1"/>
                            <field name="final_handover_date"/>
                            <field name="retention_release_stage1_done" readonly="1"/>
                            <field name="retention_release_stage1_amount" readonly="1"/>
                            <field name="retention_release_stage2_done" readonly="1"/>
                            <field name="retention_release_stage2_amount" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Punch / Snag List">
                            <div>
                                <span class="o_stat_value"><field name="punch_list_open_count"/> open</span>
                                <span class="o_stat_value"> / <field name="punch_list_total_count"/> total</span>
                            </div>
                            <field name="punch_list_ids">
                                <list editable="bottom">
                                    <field name="description"/>
                                    <field name="location"/>
                                    <field name="responsible_party"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'closed'"
                                           decoration-danger="status == 'open'"/>
                                    <field name="date_reported"/>
                                    <field name="date_closed"/>
                                    <button name="action_close_item" string="Close" type="object"
                                            icon="fa-check" invisible="status != 'open'"/>
                                    <button name="action_reopen_item" string="Reopen" type="object"
                                            icon="fa-undo" invisible="status != 'closed'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Final Acceptance">
                            <field name="final_acceptance_notes" placeholder="ملاحظات الاستلام النهائي..."/>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="أي ملاحظات إضافية..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_project_handover_list" model="ir.ui.view">
        <field name="name">project.handover.list</field>
        <field name="model">project.handover</field>
        <field name="arch" type="xml">
            <list string="Handovers" decoration-success="state == 'closed'"
                  decoration-info="state == 'provisional'" decoration-warning="state == 'final'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="provisional_handover_date"/>
                <field name="final_handover_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'closed'"
                       decoration-info="state == 'provisional'"
                       decoration-warning="state == 'final'"/>
            </list>
        </field>
    </record>

    <record id="view_project_handover_search" model="ir.ui.view">
        <field name="name">project.handover.search</field>
        <field name="model">project.handover</field>
        <field name="arch" type="xml">
            <search string="Search Handovers">
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Provisional" name="provisional" domain="[('state', '=', 'provisional')]"/>
                <filter string="Final" name="final" domain="[('state', '=', 'final')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_project_handover" model="ir.actions.act_window">
        <field name="name">Handovers / Delivery</field>
        <field name="res_model">project.handover</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_project_handover" name="Handovers"
              parent="menu_handover_section"
              action="action_project_handover" sequence="10"/>

</odoo>

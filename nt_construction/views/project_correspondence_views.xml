<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ PROJECT CORRESPONDENCE ============ -->

    <record id="view_project_correspondence_form" model="ir.ui.view">
        <field name="name">project.correspondence.form</field>
        <field name="model">project.correspondence</field>
        <field name="arch" type="xml">
            <form string="Correspondence">
                <header>
                    <button name="action_mark_sent" string="Mark as Sent / Received" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="state not in ('sent', 'responded')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,sent,responded,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="direction"/>
                            <field name="correspondence_type"/>
                            <field name="date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="reference_number"/>
                            <field name="sender_id"/>
                            <field name="recipient_id"/>
                            <field name="response_required"/>
                            <field name="response_deadline" invisible="not response_required"/>
                        </group>
                    </group>
                    <group string="Subject">
                        <field name="subject" nolabel="1"/>
                    </group>
                    <group string="Content">
                        <field name="body" nolabel="1" placeholder="محتوى الخطاب..."/>
                    </group>
                    <field name="attachment_ids" widget="many2many_binary" string="Attachments"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_project_correspondence_list" model="ir.ui.view">
        <field name="name">project.correspondence.list</field>
        <field name="model">project.correspondence</field>
        <field name="arch" type="xml">
            <list string="Correspondence" decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="direction" widget="badge"
                       decoration-info="direction == 'incoming'"
                       decoration-success="direction == 'outgoing'"/>
                <field name="correspondence_type"/>
                <field name="subject"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('sent', 'responded')"
                       decoration-muted="state == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="view_project_correspondence_search" model="ir.ui.view">
        <field name="name">project.correspondence.search</field>
        <field name="model">project.correspondence</field>
        <field name="arch" type="xml">
            <search string="Search Correspondence">
                <field name="name"/>
                <field name="project_id"/>
                <field name="subject"/>
                <field name="reference_number"/>
                <filter string="Incoming" name="incoming" domain="[('direction', '=', 'incoming')]"/>
                <filter string="Outgoing" name="outgoing" domain="[('direction', '=', 'outgoing')]"/>
                <filter string="Open" name="open" domain="[('state', 'in', ('draft', 'sent', 'responded'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'correspondence_type'}"/>
                    <filter string="Direction" name="group_direction" context="{'group_by': 'direction'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_project_correspondence" model="ir.actions.act_window">
        <field name="name">Correspondence / Letters</field>
        <field name="res_model">project.correspondence</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
